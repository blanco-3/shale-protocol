{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/data/**",
              "components/forms/**",
              "ui_kits/shale-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Spectral|Hanken Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Spectral, Hanken Grotesk, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|outline|mono|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, outline, mono, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|ink|core|seam|apex|positive|warning|danger)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'ink' | 'core' | 'seam' | 'apex' | 'positive' | 'warning' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|size|fullWidth|disabled|iconLeft|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, tone, size, fullWidth, disabled, iconLeft, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'solid' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|core|seam|apex|accent)$/]",
        "message": "<Button> tone must be one of 'default' | 'core' | 'seam' | 'apex' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:surface|accent|pad|strataEdge|interactive|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: surface, accent, pad, strataEdge, interactive, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:paper|raised|sunken|ink)$/]",
        "message": "<Card> surface must be one of 'paper' | 'raised' | 'sunken' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='pad'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> pad must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|prefix|suffix|mono|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, prefix, suffix, mono, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='RiskMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|showLabel|dotSize|key|ref|className|style|children)$/]",
        "message": "<RiskMeter> doesn't accept that prop. Declared props: level, showLabel, dotSize."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|sub|tone|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label, sub, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:core|seam|apex|default)$/]",
        "message": "<SegmentOption> tone must be one of 'core' | 'seam' | 'apex' | 'default'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|sub|delta|deltaTone|align|key|ref|className|style|children)$/]",
        "message": "<StatTile> doesn't accept that prop. Declared props: label, value, sub, delta, deltaTone, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute[name.name='deltaTone'] > Literal[value!=/^(?:positive|danger|warning|neutral)$/]",
        "message": "<StatTile> deltaTone must be one of 'positive' | 'danger' | 'warning' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<StatTile> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StrataBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|tone|target|height|label|valueLabel|key|ref|className|style|children)$/]",
        "message": "<StrataBar> doesn't accept that prop. Declared props: value, max, tone, target, height, label, valueLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='StrataMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|wordmark|wordmarkStyle|color|key|ref|className|style|children)$/]",
        "message": "<StrataMark> doesn't accept that prop. Declared props: size, wordmark, wordmarkStyle, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='StrataMark'] > JSXAttribute[name.name='wordmarkStyle'] > Literal[value!=/^(?:serif|caps)$/]",
        "message": "<StrataMark> wordmarkStyle must be one of 'serif' | 'caps'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
